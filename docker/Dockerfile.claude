# ============================================================
# Claude Code 服务镜像（连接内网 API 版）
# ============================================================

FROM node:20-slim

# 安装系统依赖
RUN apt-get update && apt-get install -y \
    git \
    curl \
    vim \
    procps \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# 安装 Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code

# 创建工作目录
WORKDIR /app

# 创建启动脚本，支持从环境变量读取配置
RUN cat > /app/init.sh << 'EOF'
#!/bin/bash
set -e

# 创建 Claude Code 配置
mkdir -p /root/.claude

# 从环境变量生成配置
cat > /root/.claude/settings.json << CONFIG
{
  "apiUrl": "${ANTHROPIC_BASE_URL:-http://localhost:8000/v1}",
  "apiKey": "${ANTHROPIC_API_KEY:-}",
  "model": "${CLAUDE_CODE_MODEL:-gpt-4}",
  "maxTokens": 4096,
  "temperature": 0.7,
  "timeout": 120,
  "customHeaders": {}
}
CONFIG

echo "Claude Code 配置:"
echo "  API URL: $ANTHROPIC_BASE_URL"
echo "  Model: $CLAUDE_CODE_MODEL"

# 验证连接（可选）
if [ -n "$ANTHROPIC_BASE_URL" ]; then
    echo "测试 API 连接..."
    curl -s -o /dev/null -w "%{http_code}" "$ANTHROPIC_BASE_URL/models" || echo "警告: API 连接测试失败"
fi

# 启动 Web 服务
exec node /app/server.js
EOF

RUN chmod +x /app/init.sh

# 创建简单的 Web 界面
RUN cat > /app/server.js << 'EOF'
const http = require('http');
const { spawn, exec } = require('child_process');
const path = require('path');
const fs = require('fs');

const PORT = process.env.PORT || 3000;
const HOST = process.env.HOST || '0.0.0.0';
const WORKSPACE = process.env.WORKSPACE_DIR || '/workspace';

// 读取配置
const configPath = '/root/.claude/settings.json';
let claudeConfig = {};
try {
    claudeConfig = JSON.parse(fs.readFileSync(configPath, 'utf8'));
} catch (e) {
    console.log('使用默认配置');
}

// HTML 界面
const HTML_TEMPLATE = `
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Claude Code - AI Assistant</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { 
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #0d1117;
            color: #c9d1d9;
            height: 100vh;
            display: flex;
            flex-direction: column;
        }
        .header { 
            background: #161b22; 
            padding: 15px 25px;
            border-bottom: 1px solid #30363d;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .header h1 { 
            font-size: 18px; 
            color: #f0f6fc;
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .badge {
            background: #238636;
            color: white;
            padding: 3px 10px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 500;
        }
        .container { 
            flex: 1; 
            display: flex; 
            overflow: hidden;
        }
        .sidebar { 
            width: 300px; 
            background: #161b22;
            border-right: 1px solid #30363d;
            padding: 20px;
            overflow-y: auto;
        }
        .sidebar h3 { 
            font-size: 12px; 
            text-transform: uppercase;
            color: #8b949e;
            margin-bottom: 15px;
            letter-spacing: 0.5px;
        }
        .config-item {
            background: #0d1117;
            border: 1px solid #30363d;
            border-radius: 6px;
            padding: 12px;
            margin-bottom: 12px;
        }
        .config-label {
            font-size: 11px;
            color: #8b949e;
            text-transform: uppercase;
            margin-bottom: 5px;
        }
        .config-value {
            font-size: 13px;
            color: #58a6ff;
            font-family: 'SF Mono', Monaco, monospace;
            word-break: break-all;
        }
        .main { 
            flex: 1; 
            display: flex;
            flex-direction: column;
            padding: 25px;
            overflow-y: auto;
        }
        .status-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin-bottom: 25px;
        }
        .status-card {
            background: #161b22;
            border: 1px solid #30363d;
            border-radius: 8px;
            padding: 20px;
        }
        .status-card h4 {
            font-size: 12px;
            color: #8b949e;
            text-transform: uppercase;
            margin-bottom: 10px;
        }
        .status-card .value {
            font-size: 24px;
            font-weight: 600;
            color: #3fb950;
        }
        .actions {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            margin-bottom: 25px;
        }
        .btn {
            background: #238636;
            color: white;
            border: none;
            padding: 12px 24px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 500;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: background 0.2s;
        }
        .btn:hover { background: #2ea043; }
        .btn-secondary {
            background: #21262d;
            border: 1px solid #30363d;
        }
        .btn-secondary:hover { background: #30363d; }
        .info-box {
            background: #161b22;
            border: 1px solid #30363d;
            border-radius: 8px;
            padding: 20px;
            margin-bottom: 20px;
        }
        .info-box h3 {
            font-size: 14px;
            margin-bottom: 15px;
            color: #f0f6fc;
        }
        .info-box code {
            background: #0d1117;
            padding: 2px 6px;
            border-radius: 3px;
            font-family: 'SF Mono', Monaco, monospace;
            font-size: 12px;
            color: #a5d6ff;
        }
        .info-box pre {
            background: #0d1117;
            padding: 15px;
            border-radius: 6px;
            overflow-x: auto;
            margin-top: 10px;
        }
        .command-list {
            list-style: none;
        }
        .command-list li {
            padding: 8px 0;
            border-bottom: 1px solid #21262d;
            font-size: 13px;
        }
        .command-list li:last-child { border-bottom: none; }
        .command-list code {
            color: #7ee787;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>🤖 Claude Code <span class="badge">Active</span></h1>
        <a href="/" class="btn btn-secondary">← Back to IDE</a>
    </div>
    <div class="container">
        <div class="sidebar">
            <h3>Configuration</h3>
            <div class="config-item">
                <div class="config-label">API Endpoint</div>
                <div class="config-value">${claudeConfig.apiUrl || 'Not configured'}</div>
            </div>
            <div class="config-item">
                <div class="config-label">Model</div>
                <div class="config-value">${claudeConfig.model || 'Default'}</div>
            </div>
            <div class="config-item">
                <div class="config-label">API Key</div>
                <div class="config-value">${claudeConfig.apiKey ? '✓ Configured' : '✗ Not set'}</div>
            </div>
            
            <h3 style="margin-top: 25px;">Quick Links</h3>
            <div class="config-item">
                <a href="/api/llm/docs" style="color: #58a6ff; text-decoration: none;">📚 API Documentation</a>
            </div>
            <div class="config-item">
                <a href="/files/" style="color: #58a6ff; text-decoration: none;">📁 File Browser</a>
            </div>
        </div>
        
        <div class="main">
            <div class="status-grid">
                <div class="status-card">
                    <h4>Service Status</h4>
                    <div class="value">● Online</div>
                </div>
                <div class="status-card">
                    <h4>API Connection</h4>
                    <div class="value">${claudeConfig.apiUrl ? '✓ Ready' : '⚠ Pending'}</div>
                </div>
            </div>
            
            <div class="actions">
                <a href="/" class="btn">🚀 Open VS Code</a>
                <a href="/api/llm/" class="btn btn-secondary">🔌 Test API</a>
            </div>
            
            <div class="info-box">
                <h3>Getting Started</h3>
                <p>Open VS Code terminal and run Claude Code commands:</p>
                <ul class="command-list">
                    <li><code>claude</code> — Start interactive session</li>
                    <li><code>claude &lt;file&gt;</code> — Edit a specific file</li>
                    <li><code>claude config get</code> — View current configuration</li>
                    <li><code>claude config set model &lt;model&gt;</code> — Switch model</li>
                </ul>
            </div>
            
            <div class="info-box">
                <h3>Configuration via Environment Variables</h3>
                <p>Set these in your <code>docker/.env</code> file:</p>
                <pre><code>LLM_API_URL=https://your-internal-llm.company.com/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=gpt-4</code></pre>
            </div>
        </div>
    </div>
</body>
</html>
`;

const server = http.createServer((req, res) => {
    if (req.url === '/' || req.url === '/index.html') {
        res.writeHead(200, { 'Content-Type': 'text/html' });
        res.end(HTML_TEMPLATE);
    } else if (req.url === '/health') {
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ 
            status: 'ok', 
            service: 'claude-web',
            apiUrl: claudeConfig.apiUrl || null,
            model: claudeConfig.model || null
        }));
    } else if (req.url === '/api/config') {
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({
            apiUrl: claudeConfig.apiUrl || null,
            model: claudeConfig.model || null,
            hasKey: !!claudeConfig.apiKey
        }));
    } else {
        res.writeHead(404);
        res.end('Not Found');
    }
});

server.listen(PORT, HOST, () => {
    console.log(`Claude Web server running at http://${HOST}:${PORT}/`);
    console.log(`API URL: ${claudeConfig.apiUrl || 'not configured'}`);
});
EOF

EXPOSE 3000

CMD ["/app/init.sh"]
