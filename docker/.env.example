# ============================================================
# 环境变量配置
# 复制为 .env 后修改
# ============================================================

# ========================================
# 基础服务配置
# ========================================
GATEWAY_PORT=8443
CODE_SERVER_PASSWORD=YourSecurePassword123
SUDO_PASSWORD=YourSudoPassword123

# ========================================
# 内网大模型 API 配置（关键）
# ========================================
# OpenAI 兼容的 API 端点
LLM_API_URL=https://your-internal-llm.company.com/v1

# API 密钥
LLM_API_KEY=your-api-key-here

# 模型名称
LLM_MODEL=gpt-4

# 内网 API 服务器 IP（用于 hosts 解析，如果需要通过 IP 访问）
# LLM_HOST_IP=10.0.0.100

# ========================================
# Claude Code 额外配置
# ========================================
CLAUDE_CODE_MODEL=gpt-4

# ========================================
# 开发环境配置
# ========================================
DEFAULT_WORKSPACE=/workspace

# ========================================
# 可选：外部网络配置
# ========================================
# HTTP_PROXY=http://proxy.company.com:8080
# HTTPS_PROXY=http://proxy.company.com:8080
# NO_PROXY=localhost,127.0.0.1,internal-llm
