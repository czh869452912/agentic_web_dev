# ============================================================
# 环境变量配置（复制为 .env 后修改）
# ============================================================

# ---- 服务访问 ----
GATEWAY_PORT=8443
CODE_SERVER_PASSWORD=YourSecurePassword123
SUDO_PASSWORD=YourSudoPassword123

# ---- Claude Code API 配置 ----
#
# 方案 A：使用 Anthropic 官方 API（有公网访问）
#   ANTHROPIC_API_KEY=sk-ant-...
#   ANTHROPIC_BASE_URL=   # 留空，使用默认
#
# 方案 B：使用内网 Anthropic API 格式代理
#   必须实现 Anthropic 消息协议（/v1/messages），而非 OpenAI 格式
#   ANTHROPIC_API_KEY=your-proxy-key
#   ANTHROPIC_BASE_URL=http://10.0.0.100:8000
#
# 方案 C：使用 LiteLLM 统一网关（内网 OpenAI 兼容 API → Anthropic 格式转换）
#   见下方 LiteLLM 配置，启动时加 --llm 标志
#   ANTHROPIC_API_KEY=sk-devenv         # 与 LITELLM_MASTER_KEY 保持一致
#   ANTHROPIC_BASE_URL=http://llm-gateway:4000  # 容器内直连，无 SSL 开销
#
# 方案 D：不配置，启动后在 code-server 终端执行 'claude' 完成交互式登录

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# ---- LiteLLM 统一 LLM 网关（可选，方案 C）----
#
# 前置条件:
#   cp configs/litellm_config.yaml.example configs/litellm_config.yaml
#   编辑 configs/litellm_config.yaml 填写内网 API 地址和模型名
#
# 启动方式:
#   ./manage.sh up --llm              (有 docker compose 环境)
#   ./manage.sh up --llm --docker-only (无 docker compose 环境)
#
# 统一后所有工具（Claude Code、Cline、Roo Code）使用同一个 key，无需单独登录
# Claude Code: ANTHROPIC_BASE_URL=http://llm-gateway:4000, ANTHROPIC_API_KEY=sk-devenv
# Cline/Roo:   OpenAI Base URL=https://<host>:8443/llm, API Key=sk-devenv

INTERNAL_API_BASE=http://10.0.0.1:8000
INTERNAL_API_KEY=your-internal-api-key
LITELLM_MASTER_KEY=sk-devenv
