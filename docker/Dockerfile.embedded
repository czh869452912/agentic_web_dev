# ============================================================
# 嵌入式开发完整工具链镜像（重型工具，与 code-server 共享 workspace）
# ============================================================

FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=Asia/Shanghai

LABEL maintainer="DevOps Team"
LABEL description="Complete embedded software engineering toolchain"
LABEL version="2.0.0"

# ============================================================
# 第一阶段：基础系统
# ============================================================
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates curl wget git git-lfs \
    vim nano less htop tree jq \
    unzip zip tar gzip bzip2 xz-utils \
    build-essential cmake ninja-build make \
    autoconf automake libtool pkg-config \
    net-tools iputils-ping dnsutils netcat socat \
    gdb gdb-multiarch strace ltrace \
    python3 python3-pip python3-venv \
    python3-setuptools python3-wheel \
    libssl-dev libffi-dev libusb-1.0-0-dev \
    libncurses5-dev libncursesw5-dev \
    && rm -rf /var/lib/apt/lists/*

# ============================================================
# 第二阶段：ARM bare-metal 工具链
# ============================================================
ENV ARM_GCC_VERSION=13.2.rel1
RUN mkdir -p /opt/toolchains \
    && wget -q --timeout=300 \
       "https://developer.arm.com/-/media/Files/downloads/gnu/${ARM_GCC_VERSION}/binrel/arm-gnu-toolchain-${ARM_GCC_VERSION}-x86_64-arm-none-eabi.tar.xz" \
       -O /tmp/arm-toolchain.tar.xz \
    && tar -xf /tmp/arm-toolchain.tar.xz -C /opt/toolchains \
    && mv /opt/toolchains/arm-gnu-toolchain-*-x86_64-arm-none-eabi /opt/toolchains/arm-none-eabi \
    && rm /tmp/arm-toolchain.tar.xz

ENV PATH="/opt/toolchains/arm-none-eabi/bin:${PATH}"

# ARM Linux 交叉编译
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc-arm-linux-gnueabihf g++-arm-linux-gnueabihf \
    gcc-aarch64-linux-gnu g++-aarch64-linux-gnu \
    && rm -rf /var/lib/apt/lists/*

# ============================================================
# 第三阶段：代码质量与静态分析
# ============================================================
RUN apt-get update && apt-get install -y --no-install-recommends \
    clang clang-format clang-tidy clang-tools llvm \
    cppcheck \
    valgrind \
    lcov \
    splint \
    && rm -rf /var/lib/apt/lists/*

RUN pip3 install --no-cache-dir gcovr

# ============================================================
# 第四阶段：文档生成
# ============================================================
RUN apt-get update && apt-get install -y --no-install-recommends \
    doxygen graphviz \
    && rm -rf /var/lib/apt/lists/*

RUN pip3 install --no-cache-dir \
    sphinx \
    sphinx-rtd-theme \
    breathe \
    exhale

# ============================================================
# 第五阶段：版本控制工具
# ============================================================
RUN apt-get update && apt-get install -y --no-install-recommends \
    git-email git-svn tig \
    && rm -rf /var/lib/apt/lists/*

RUN apt-get update && apt-get install -y --no-install-recommends git-review \
    && rm -rf /var/lib/apt/lists/*

# ============================================================
# 第六阶段：构建系统
# ============================================================
RUN pip3 install --no-cache-dir meson scons conan

# ============================================================
# 第七阶段：测试框架
# ============================================================
RUN apt-get update && apt-get install -y --no-install-recommends \
    libgtest-dev libcmocka-dev \
    && cd /usr/src/googletest \
    && cmake . && make && make install \
    && rm -rf /var/lib/apt/lists/*

# Unity / CMock / CException（嵌入式单元测试）
RUN mkdir -p /opt/test-frameworks \
    && git clone --depth 1 https://github.com/ThrowTheSwitch/Unity.git    /opt/test-frameworks/Unity \
    && git clone --depth 1 https://github.com/ThrowTheSwitch/CMock.git    /opt/test-frameworks/CMock \
    && git clone --depth 1 https://github.com/ThrowTheSwitch/CException.git /opt/test-frameworks/CException

# ============================================================
# 第八阶段：QEMU 模拟器
# ============================================================
RUN apt-get update && apt-get install -y --no-install-recommends \
    qemu-user-static \
    qemu-system-arm \
    qemu-system-aarch64 \
    binfmt-support \
    && rm -rf /var/lib/apt/lists/*

# ============================================================
# 第九阶段：OpenOCD / 调试器
# ============================================================
RUN apt-get update && apt-get install -y --no-install-recommends \
    openocd \
    stlink-tools \
    libftdi1-dev \
    libhidapi-dev \
    && rm -rf /var/lib/apt/lists/*

# ============================================================
# 第十阶段：Rust（嵌入式）
# ============================================================
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
ENV PATH="/root/.cargo/bin:${PATH}"

RUN rustup target add \
    thumbv7m-none-eabi \
    thumbv7em-none-eabihf \
    thumbv8m.main-none-eabi \
    aarch64-unknown-none-softfloat

RUN cargo install cargo-embed probe-rs-tools --locked

# ============================================================
# 第十一阶段：Python 嵌入式工具
# ============================================================
RUN pip3 install --no-cache-dir \
    pyserial \
    pyusb \
    pyocd \
    esptool \
    pyelftools \
    pycparser \
    cffi

# ============================================================
# 第十二阶段：二进制分析 + 其他工具
# ============================================================
RUN apt-get update && apt-get install -y --no-install-recommends \
    binwalk \
    xxd \
    cloc \
    indent \
    astyle \
    && rm -rf /var/lib/apt/lists/*

# ============================================================
# 第十三阶段：Claude Code CLI（通过 NodeSource 安装 Node.js）
# ============================================================
ENV NODE_MAJOR=20
RUN curl -fsSL https://deb.nodesource.com/setup_${NODE_MAJOR}.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

RUN npm install -g @anthropic-ai/claude-code

# ============================================================
# 第十四阶段：环境配置（外部文件，避免 heredoc 解析问题）
# ============================================================

# Git 全局配置
RUN git config --global init.defaultBranch main \
    && git config --global color.ui auto \
    && git config --global core.editor vim

# 工具链配置文件（用 printf 避免 heredoc）
RUN mkdir -p /etc/dev-env \
    && printf '# 嵌入式开发环境工具链配置\nARM_TOOLCHAIN_PATH=/opt/toolchains/arm-none-eabi/bin\nTEST_FRAMEWORK_PATH=/opt/test-frameworks\nCMAKE_GENERATOR=Ninja\n' \
       > /etc/dev-env/tools.conf

# bashrc 增强（COPY 外部文件，追加到 .bashrc）
COPY scripts/embedded-bashrc.sh /tmp/embedded-bashrc.sh
RUN sed -i 's/\r$//' /tmp/embedded-bashrc.sh \
    && cat /tmp/embedded-bashrc.sh >> /root/.bashrc \
    && rm /tmp/embedded-bashrc.sh

# Vim 配置
COPY scripts/embedded-vimrc /root/.vimrc
RUN sed -i 's/\r$//' /root/.vimrc

# clang-format 配置
COPY scripts/embedded-clang-format /root/.clang-format
RUN sed -i 's/\r$//' /root/.clang-format

# ============================================================
# 工作目录
# ============================================================
WORKDIR /workspace
VOLUME ["/workspace", "/opt/toolchains", "/opt/test-frameworks"]

HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD arm-none-eabi-gcc --version && clang-tidy --version && cppcheck --version || exit 1

CMD ["/bin/bash"]
