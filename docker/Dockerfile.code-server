# ============================================================
# Code Server + Claude Code 一体化镜像
# VS Code Web IDE，内置 Claude Code CLI，可直接在终端使用
# ============================================================

FROM codercom/code-server:latest

USER root

# ============================================================
# 切换到阿里云镜像（解决中国大陆网络问题，兼容 Ubuntu/Debian）
# ============================================================
RUN if [ -f /etc/apt/sources.list ] && grep -q "ubuntu" /etc/apt/sources.list 2>/dev/null; then \
        sed -i 's|http://archive.ubuntu.com/ubuntu|http://mirrors.aliyun.com/ubuntu|g' /etc/apt/sources.list && \
        sed -i 's|http://security.ubuntu.com/ubuntu|http://mirrors.aliyun.com/ubuntu|g' /etc/apt/sources.list; \
    elif [ -f /etc/apt/sources.list.d/debian.sources ]; then \
        sed -i 's|http://deb.debian.org/debian|http://mirrors.aliyun.com/debian|g' /etc/apt/sources.list.d/debian.sources && \
        sed -i 's|http://security.debian.org/debian-security|http://mirrors.aliyun.com/debian-security|g' /etc/apt/sources.list.d/debian.sources; \
    elif [ -f /etc/apt/sources.list ]; then \
        sed -i 's|http://deb.debian.org/debian|http://mirrors.aliyun.com/debian|g' /etc/apt/sources.list && \
        sed -i 's|http://security.debian.org|http://mirrors.aliyun.com/debian-security|g' /etc/apt/sources.list; \
    fi

# ============================================================
# 系统依赖 + 嵌入式开发基础工具
# ============================================================
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    wget \
    git \
    git-lfs \
    vim \
    nano \
    htop \
    tree \
    jq \
    unzip \
    zip \
    build-essential \
    gdb \
    gdb-multiarch \
    cmake \
    ninja-build \
    clang \
    clang-format \
    clang-tidy \
    clang-tools \
    llvm \
    cppcheck \
    valgrind \
    lcov \
    doxygen \
    graphviz \
    gcc-arm-linux-gnueabihf \
    g++-arm-linux-gnueabihf \
    gcc-aarch64-linux-gnu \
    g++-aarch64-linux-gnu \
    python3 \
    python3-pip \
    python3-venv \
    openocd \
    && rm -rf /var/lib/apt/lists/*

# ============================================================
# Python 工具
# ============================================================
RUN pip3 install --no-cache-dir --break-system-packages \
    gcovr \
    pyserial \
    pyelftools \
    meson \
    autopep8

# ============================================================
# ARM bare-metal 工具链（arm-none-eabi）
# ============================================================
ENV ARM_GCC_VERSION=13.2.rel1
RUN mkdir -p /opt/toolchains \
    && wget -q --timeout=300 \
       "https://developer.arm.com/-/media/Files/downloads/gnu/${ARM_GCC_VERSION}/binrel/arm-gnu-toolchain-${ARM_GCC_VERSION}-x86_64-arm-none-eabi.tar.xz" \
       -O /tmp/arm-toolchain.tar.xz \
    && tar -xf /tmp/arm-toolchain.tar.xz -C /opt/toolchains \
    && mv /opt/toolchains/arm-gnu-toolchain-*-x86_64-arm-none-eabi /opt/toolchains/arm-none-eabi \
    && rm /tmp/arm-toolchain.tar.xz

ENV PATH="/opt/toolchains/arm-none-eabi/bin:${PATH}"

# ============================================================
# Node.js + Claude Code CLI
# ============================================================
ENV NODE_MAJOR=20
RUN curl -fsSL https://deb.nodesource.com/setup_${NODE_MAJOR}.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

RUN npm install -g @anthropic-ai/claude-code

# ============================================================
# VS Code 插件（安装到 seed 目录，不被 volume 覆盖）
# entrypoint 启动时自动合并到实际 extensions 目录
# ============================================================
ENV CODE_SERVER_EXTENSIONS_SEED=/opt/code-server-extensions-seed

RUN mkdir -p ${CODE_SERVER_EXTENSIONS_SEED}

RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension ms-vscode.cpptools-extension-pack
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension marus25.cortex-debug
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension dan-c-underwood.arm
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension zixuanwang.linkerscript
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension jbenden.c-cpp-flylint
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension xaver.clang-format
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension notskm.clang-tidy
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension cschlosser.doxdocgen
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension ms-vscode.cmake-tools
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension twxs.cmake
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension eamodio.gitlens
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension mhutchie.git-graph
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension pkief.material-icon-theme
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension streetsidesoftware.code-spell-checker
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension usernamehw.errorlens
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension christian-kohler.path-intellisense

# Claude Code 官方扩展（在线时安装，离线时跳过）
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension anthropic.claude-code \
    || echo "[INFO] Claude Code extension not in marketplace, use VSIX instead"

# Cline 备选
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension saoudrizwan.claude-dev \
    || echo "[INFO] Cline not available, skipping"

# ============================================================
# 离线 VSIX 安装（将 .vsix 放在 configs/vsix/ 目录）
# ============================================================
RUN mkdir -p /tmp/vsix
COPY configs/vsix/ /tmp/vsix/
RUN if ls /tmp/vsix/*.vsix 1>/dev/null 2>&1; then \
        for vsix in /tmp/vsix/*.vsix; do \
            echo "Installing: $vsix" && \
            code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension "$vsix" || echo "Failed: $vsix"; \
        done; \
    else \
        echo "[INFO] No VSIX files, skipping offline install"; \
    fi

# ============================================================
# 配置和启动脚本
# ============================================================
USER root

# VS Code 工作区默认设置
COPY --chown=coder:coder configs/settings.json /home/coder/.local/share/code-server/User/settings.json

# 嵌入式工具别名写入系统级 profile（容器以 root 运行，/home/coder/.bashrc 不会被加载）
RUN printf '# ==== Embedded Dev Environment ====\n\
export PATH="/opt/toolchains/arm-none-eabi/bin:$PATH"\n\
alias arm-gcc="arm-none-eabi-gcc"\n\
alias arm-objdump="arm-none-eabi-objdump"\n\
alias arm-size="arm-none-eabi-size"\n\
alias cf="clang-format"\n\
alias ct="clang-tidy"\n\
alias cppc="cppcheck --enable=all --suppress=missingIncludeSystem"\n\
alias cov="gcovr -r . --html --html-details -o coverage.html"\n' \
    > /etc/profile.d/embedded-dev.sh \
    && cat /etc/profile.d/embedded-dev.sh >> /etc/bash.bashrc

# 启动脚本（外部文件，避免 heredoc 解析问题）
COPY scripts/code-server-entrypoint.sh /opt/entrypoint.sh
# 修复 Windows CRLF 行尾，确保 shebang 可被 Linux 识别
RUN sed -i 's/\r$//' /opt/entrypoint.sh && chmod +x /opt/entrypoint.sh

ENV SHELL=/bin/bash
WORKDIR /workspace

ENTRYPOINT ["/opt/entrypoint.sh"]
CMD []
