# 所有文本文件默认使用 LF（避免 Windows CRLF 破坏 Linux 脚本）
* text=auto eol=lf

# Shell 脚本强制 LF
*.sh    text eol=lf
*.bash  text eol=lf

# Windows 专用脚本保留 CRLF
*.ps1   text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf

# 二进制文件
*.vsix  binary
*.tar   binary
*.gz    binary
*.xz    binary
*.png   binary
*.jpg   binary
